{
    "Serilog": {
        "Using": [ "Serilog.Sinks.File" ],
        "MinimumLevel": {
            "Default": "Information",
            "Override": { "Microsoft.AspNetCore": "Warning" }
        },
        "WriteTo": [
            {
                "Name": "File",
                "Args": {
                    "path": "../logs/radar-api-.log",
                    "rollingInterval": "Day",
                    "outputTemplate": "{Timestamp:yyyy-MM-dd HH:mm:ss.fff zzz} [{Level:u3}] {Message:lj}{NewLine}{Exception}"
                }
            }
        ]
    },
    "ApiLinks": [
        {
            "ApiName": "VisualSoft.Surveillance.Management.Api",
            "Links": [
                {
                    "Key": "AllOrganisations",
                    "Path": "api/organisations"
                },
                {
                    "Key": "Login",
                    "Path": "api/login"
                }
            ]
        }
    ],
    "ApiLinkUrl": {
        "VisualSoft.Surveillance.Management.Api": "https://localhost:7001"
    },
    "Connections": {
        "PostgresConnectionString": "Host=your_host;Database=your_db;Username=your_user;Password=your_pass"
    },
    "AllowedHosts": "*"
}